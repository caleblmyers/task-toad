{
  "name": "task-toad",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:order": "pnpm --filter api build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "pnpm -r run typecheck",
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "deploy": "pnpm --filter infra cdk deploy"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}
