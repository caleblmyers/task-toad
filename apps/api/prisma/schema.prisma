datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Org {
  orgId           String    @id @default(uuid()) @map("org_id")
  name            String
  createdAt       DateTime  @default(now()) @map("created_at")
  anthropicApiKeyEncrypted String?   @map("anthropic_api_key_encrypted")
  users           User[]
  projects        Project[]
  sprints         Sprint[]
  invites         OrgInvite[]
  labels          Label[]

  @@map("orgs")
}

model User {
  userId              String    @id @default(uuid()) @map("user_id")
  email               String    @unique
  passwordHash        String    @map("password_hash")
  orgId               String?   @map("org_id")
  role                String?
  emailVerifiedAt     DateTime? @map("email_verified_at")
  verificationToken   String?   @unique @map("verification_token")
  resetToken          String?   @unique @map("reset_token")
  resetTokenExpiry    DateTime? @map("reset_token_expiry")
  org                 Org?      @relation(fields: [orgId], references: [orgId])
  assignedTasks       Task[]    @relation("TaskAssignee")
  comments            Comment[] @relation("UserComments")
  activities          Activity[] @relation("UserActivities")
  notifications       Notification[] @relation("UserNotifications")

  @@map("users")
}

model OrgInvite {
  inviteId   String    @id @default(uuid()) @map("invite_id")
  orgId      String    @map("org_id")
  email      String
  token      String    @unique
  role       String    @default("org:member")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")
  org        Org       @relation(fields: [orgId], references: [orgId])

  @@index([token])
  @@index([orgId])
  @@map("org_invites")
}

model Project {
  projectId             String   @id @default(uuid()) @map("project_id")
  orgId                 String   @map("org_id")
  name                  String
  description           String?
  prompt                String?
  statuses              String   @default("[\"todo\",\"in_progress\",\"in_review\",\"done\"]")
  createdAt             DateTime @default(now()) @map("created_at")
  archived              Boolean  @default(false)
  githubRepositoryId    String?  @map("github_repository_id")
  githubRepositoryName  String?  @map("github_repository_name")
  githubRepositoryOwner String?  @map("github_repository_owner")
  githubInstallationId  String?  @map("github_installation_id")
  githubDefaultBranch   String?  @map("github_default_branch")
  org                   Org      @relation(fields: [orgId], references: [orgId])
  tasks                 Task[]
  sprints               Sprint[]

  @@index([orgId])
  @@map("projects")
}

model Sprint {
  sprintId  String    @id @default(uuid()) @map("sprint_id")
  orgId     String    @map("org_id")
  projectId String    @map("project_id")
  name      String
  goal      String?   @map("goal")
  isActive  Boolean   @default(false) @map("is_active")
  columns   String    @default("[\"To Do\",\"In Progress\",\"In Review\",\"Done\"]")
  startDate String?   @map("start_date")
  endDate   String?   @map("end_date")
  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")
  org       Org       @relation(fields: [orgId], references: [orgId])
  project   Project   @relation(fields: [projectId], references: [projectId])
  tasks     Task[]

  @@index([projectId])
  @@map("sprints")
}

model Task {
  taskId         String   @id @default(uuid()) @map("task_id")
  orgId          String   @map("org_id")
  projectId      String   @map("project_id")
  parentTaskId   String?  @map("parent_task_id")
  title          String
  description    String?
  instructions   String?
  suggestedTools String?  @map("suggested_tools")
  estimatedHours Float?   @map("estimated_hours")
  storyPoints    Int?     @map("story_points")
  priority       String   @default("medium")
  dependsOn      String?  @map("depends_on")
  status         String   @default("todo")
  sprintId       String?  @map("sprint_id")
  sprintColumn   String?  @map("sprint_column")
  assigneeId     String?  @map("assignee_id")
  position       Float?   @map("position")
  dueDate        String?  @map("due_date")
  createdAt      DateTime @default(now()) @map("created_at")
  archived       Boolean  @default(false)
  project        Project  @relation(fields: [projectId], references: [projectId])
  parentTask     Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [taskId])
  subtasks       Task[]   @relation("TaskSubtasks")
  sprint         Sprint?  @relation(fields: [sprintId], references: [sprintId])
  assignee       User?    @relation("TaskAssignee", fields: [assigneeId], references: [userId])
  githubIssueNumber Int?    @map("github_issue_number")
  githubIssueNodeId  String? @map("github_issue_node_id")
  comments       Comment[]
  labels         TaskLabel[]
  pullRequests   GitHubPullRequestLink[]
  commits        GitHubCommitLink[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([orgId])
  @@index([projectId, sprintId, position])
  @@map("tasks")
}

model Comment {
  commentId       String    @id @default(uuid()) @map("comment_id")
  taskId          String    @map("task_id")
  userId          String    @map("user_id")
  parentCommentId String?   @map("parent_comment_id")
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  task            Task      @relation(fields: [taskId], references: [taskId], onDelete: Cascade)
  user            User      @relation("UserComments", fields: [userId], references: [userId])
  parentComment   Comment?  @relation("CommentThread", fields: [parentCommentId], references: [commentId])
  replies         Comment[] @relation("CommentThread")

  @@index([taskId])
  @@index([parentCommentId])
  @@map("comments")
}

model Activity {
  activityId String   @id @default(uuid()) @map("activity_id")
  orgId      String   @map("org_id")
  projectId  String?  @map("project_id")
  taskId     String?  @map("task_id")
  sprintId   String?  @map("sprint_id")
  userId     String   @map("user_id")
  action     String
  field      String?
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation("UserActivities", fields: [userId], references: [userId])

  @@index([projectId])
  @@index([taskId])
  @@index([orgId, createdAt])
  @@map("activities")
}

model Label {
  labelId   String      @id @default(uuid()) @map("label_id")
  orgId     String      @map("org_id")
  name      String
  color     String      @default("#6b7280")
  createdAt DateTime    @default(now()) @map("created_at")
  org       Org         @relation(fields: [orgId], references: [orgId])
  tasks     TaskLabel[]
  @@unique([orgId, name])
  @@index([orgId])
  @@map("labels")
}

model TaskLabel {
  taskId    String   @map("task_id")
  labelId   String   @map("label_id")
  createdAt DateTime @default(now()) @map("created_at")
  task      Task     @relation(fields: [taskId], references: [taskId], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [labelId], onDelete: Cascade)
  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

model GitHubInstallation {
  installationId String   @id @map("installation_id")
  accountLogin   String   @map("account_login")
  accountType    String   @map("account_type")
  orgId          String?  @map("org_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@map("github_installations")
}

model GitHubCommitLink {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [taskId])
  sha       String
  message   String
  author    String
  url       String
  createdAt DateTime @default(now())
  @@index([taskId])
  @@unique([sha, taskId])
  @@map("github_commit_links")
}

model GitHubPullRequestLink {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [taskId])
  prNodeId  String   @map("pr_node_id")
  prNumber  Int      @map("pr_number")
  prUrl     String   @map("pr_url")
  prTitle   String   @map("pr_title")
  state     String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([taskId])
  @@map("github_pull_request_links")
}

model Notification {
  notificationId   String   @id @default(uuid()) @map("notification_id")
  orgId            String   @map("org_id")
  userId           String   @map("user_id")
  type             String
  title            String
  body             String?
  linkUrl          String?  @map("link_url")
  relatedTaskId    String?  @map("related_task_id")
  relatedProjectId String?  @map("related_project_id")
  isRead           Boolean  @default(false) @map("is_read")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation("UserNotifications", fields: [userId], references: [userId])
  @@index([userId, isRead, createdAt])
  @@index([orgId])
  @@map("notifications")
}
