model User {
  userId              String    @id @default(uuid()) @map("user_id")
  email               String    @unique
  passwordHash        String    @map("password_hash")
  orgId               String?   @map("org_id")
  role                String?
  emailVerifiedAt     DateTime? @map("email_verified_at")
  verificationToken       String?   @unique @map("verification_token")
  verificationTokenExpiry DateTime? @map("verification_token_expiry")
  resetToken              String?   @unique @map("reset_token")
  resetTokenExpiry        DateTime? @map("reset_token_expiry")
  org                 Org?      @relation(fields: [orgId], references: [orgId])
  assignedTasks       Task[]    @relation("TaskAssignee")
  comments            Comment[] @relation("UserComments")
  activities          Activity[] @relation("UserActivities")
  notifications       Notification[] @relation("UserNotifications")
  notificationPreferences NotificationPreference[]
  aiUsageLogs         AIUsageLog[]
  reports             Report[]
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  timezone     String?  @default("UTC")
  projectMemberships ProjectMember[]
  emailNotificationsEnabled Boolean @default(false) @map("email_notifications_enabled")
  savedFilters      SavedFilter[]
  slackUserMappings SlackUserMapping[]
  taskAssignments   TaskAssignee[] @relation("TaskAssignees")
  taskWatches       TaskWatcher[]  @relation("TaskWatchers")
  attachments       Attachment[]   @relation("UserAttachments")
  releases          Release[]      @relation("UserReleases")
  timeEntries       TimeEntry[]    @relation("UserTimeEntries")
  userCapacities    UserCapacity[]
  userTimeOffs      UserTimeOff[]
  tokenVersion      Int            @default(0) @map("token_version")
  githubLogin       String?        @map("github_login")
  githubTokenEncrypted String?     @map("github_token_encrypted")
  refreshTokens     RefreshToken[]
  approvalRequests  Approval[]     @relation("ApprovalRequester")
  approvalDecisions Approval[]     @relation("ApprovalApprover")

  @@index([orgId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OrgInvite {
  inviteId   String    @id @default(uuid()) @map("invite_id")
  orgId      String    @map("org_id")
  email      String
  token      String    @unique
  role       String    @default("org:member")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")
  org        Org       @relation(fields: [orgId], references: [orgId])

  @@index([token])
  @@index([orgId])
  @@map("org_invites")
}
