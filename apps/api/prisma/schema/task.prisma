model Task {
  taskId         String   @id @default(uuid()) @map("task_id")
  orgId          String   @map("org_id")
  projectId      String   @map("project_id")
  parentTaskId   String?  @map("parent_task_id")
  title          String
  description    String?
  instructions       String?
  acceptanceCriteria String?  @map("acceptance_criteria")
  suggestedTools     String?  @map("suggested_tools")
  estimatedHours Float?   @map("estimated_hours")
  storyPoints    Int?     @map("story_points")
  priority       String   @default("medium")
  dependsOn      String?  @map("depends_on")
  status         String   @default("todo")
  taskType       String   @default("task") @map("task_type")
  sprintId       String?  @map("sprint_id")
  sprintColumn   String?  @map("sprint_column")
  assigneeId     String?  @map("assignee_id")
  position       Float?   @map("position")
  dueDate        String?  @map("due_date")
  createdAt      DateTime @default(now()) @map("created_at")
  archived       Boolean  @default(false)
  project        Project  @relation(fields: [projectId], references: [projectId])
  parentTask     Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [taskId])
  subtasks       Task[]   @relation("TaskSubtasks")
  sprint         Sprint?  @relation(fields: [sprintId], references: [sprintId])
  assignee       User?    @relation("TaskAssignee", fields: [assigneeId], references: [userId])
  githubIssueNumber Int?    @map("github_issue_number")
  githubIssueNodeId  String? @map("github_issue_node_id")
  comments          Comment[]
  labels            TaskLabel[]
  pullRequests      GitHubPullRequestLink[]
  commits           GitHubCommitLink[]
  customFieldValues CustomFieldValue[]
  taskAssignees     TaskAssignee[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([orgId])
  @@index([orgId, archived])
  @@index([projectId, sprintId, position])
  @@map("tasks")
}

model CustomField {
  customFieldId String             @id @default(uuid()) @map("custom_field_id")
  orgId         String             @map("org_id")
  projectId     String             @map("project_id")
  name          String
  fieldType     String             @map("field_type") // TEXT, NUMBER, DATE, DROPDOWN
  options       String?            // JSON array for dropdown options
  required      Boolean            @default(false)
  position      Int                @default(0)
  createdAt     DateTime           @default(now()) @map("created_at")
  org           Org                @relation(fields: [orgId], references: [orgId])
  project       Project            @relation(fields: [projectId], references: [projectId])
  values        CustomFieldValue[]

  @@index([projectId])
  @@index([orgId])
  @@map("custom_fields")
}

model CustomFieldValue {
  customFieldValueId String      @id @default(uuid()) @map("custom_field_value_id")
  customFieldId      String      @map("custom_field_id")
  taskId             String      @map("task_id")
  value              String
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  customField        CustomField @relation(fields: [customFieldId], references: [customFieldId], onDelete: Cascade)
  task               Task        @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@unique([customFieldId, taskId])
  @@index([taskId])
  @@index([customFieldId])
  @@map("custom_field_values")
}

model Label {
  labelId   String      @id @default(uuid()) @map("label_id")
  orgId     String      @map("org_id")
  name      String
  color     String      @default("#6b7280")
  createdAt DateTime    @default(now()) @map("created_at")
  org       Org         @relation(fields: [orgId], references: [orgId])
  tasks     TaskLabel[]
  @@unique([orgId, name])
  @@index([orgId])
  @@map("labels")
}

model TaskLabel {
  taskId    String   @map("task_id")
  labelId   String   @map("label_id")
  createdAt DateTime @default(now()) @map("created_at")
  task      Task     @relation(fields: [taskId], references: [taskId], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [labelId], onDelete: Cascade)
  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  task       Task     @relation(fields: [taskId], references: [taskId], onDelete: Cascade)
  user       User     @relation("TaskAssignees", fields: [userId], references: [userId], onDelete: Cascade)
  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_assignees")
}
