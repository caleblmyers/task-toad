model Project {
  projectId             String   @id @default(uuid()) @map("project_id")
  orgId                 String   @map("org_id")
  name                  String
  description           String?
  prompt                String?
  knowledgeBase         String?  @map("knowledge_base")
  statuses              String   @default("[\"todo\",\"in_progress\",\"in_review\",\"done\"]")
  createdAt             DateTime @default(now()) @map("created_at")
  archived              Boolean  @default(false)
  githubRepositoryId    String?  @map("github_repository_id")
  githubRepositoryName  String?  @map("github_repository_name")
  githubRepositoryOwner String?  @map("github_repository_owner")
  githubInstallationId  String?  @map("github_installation_id")
  githubDefaultBranch   String?  @map("github_default_branch")
  org                   Org      @relation(fields: [orgId], references: [orgId])
  tasks                 Task[]
  sprints               Sprint[]
  reports               Report[]
  members               ProjectMember[]
  automationRules       AutomationRule[]
  customFields          CustomField[]
  savedFilters          SavedFilter[]
  taskTemplates         TaskTemplate[]
  transitions           WorkflowTransition[]
  releases              Release[]
  knowledgeEntries      KnowledgeEntry[]
  taskInsights          TaskInsight[]
  slaPolicies           SLAPolicy[]
  initiativeProjects    InitiativeProject[]
  fieldPermissions      FieldPermission[]

  @@index([orgId])
  @@map("projects")
}

model SavedFilter {
  savedFilterId  String   @id @default(uuid()) @map("saved_filter_id")
  projectId      String   @map("project_id")
  userId         String   @map("user_id")
  name           String
  filters        String   // JSON string of filter state
  isDefault      Boolean  @default(false) @map("is_default")
  viewType       String?  @map("view_type") // 'list' | 'board' | 'table'
  sortBy         String?  @map("sort_by")
  sortOrder      String?  @map("sort_order") // 'asc' | 'desc'
  groupBy        String?  @map("group_by")
  visibleColumns String?  @map("visible_columns") // JSON array of column names
  isShared       Boolean  @default(false) @map("is_shared")
  createdAt      DateTime @default(now()) @map("created_at")
  project        Project  @relation(fields: [projectId], references: [projectId])
  user           User     @relation(fields: [userId], references: [userId])

  @@index([projectId])
  @@index([userId])
  @@map("saved_filters")
}
