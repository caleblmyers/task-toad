model TaskInsight {
  taskInsightId String   @id @default(uuid()) @map("task_insight_id")
  sourceTaskId  String   @map("source_task_id")
  targetTaskId  String?  @map("target_task_id")
  projectId     String   @map("project_id")
  orgId         String   @map("org_id")
  type          String   // discovery, warning, pattern
  content       String   @db.Text
  autoApplied   Boolean  @default(false) @map("auto_applied")
  createdAt     DateTime @default(now()) @map("created_at")
  sourceTask    Task     @relation("InsightSource", fields: [sourceTaskId], references: [taskId], onDelete: Cascade)
  targetTask    Task?    @relation("InsightTarget", fields: [targetTaskId], references: [taskId], onDelete: SetNull)
  project       Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  org           Org      @relation(fields: [orgId], references: [orgId])
  @@index([sourceTaskId])
  @@index([targetTaskId])
  @@index([projectId])
  @@map("task_insights")
}
