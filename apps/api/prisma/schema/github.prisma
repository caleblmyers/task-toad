model GitHubInstallation {
  installationId String   @id @map("installation_id")
  accountLogin   String   @map("account_login")
  accountType    String   @map("account_type")
  orgId          String?  @map("org_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@map("github_installations")
}

model GitHubCommitLink {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [taskId])
  sha       String
  message   String
  author    String
  url       String
  createdAt DateTime @default(now())
  @@index([taskId])
  @@unique([sha, taskId])
  @@map("github_commit_links")
}

model GitHubPullRequestLink {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [taskId])
  prNodeId  String   @map("pr_node_id")
  prNumber  Int      @map("pr_number")
  prUrl     String   @map("pr_url")
  prTitle   String   @map("pr_title")
  state     String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([taskId])
  @@map("github_pull_request_links")
}
