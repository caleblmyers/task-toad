model KnowledgeEntry {
  knowledgeEntryId String   @id @default(uuid()) @map("knowledge_entry_id")
  projectId        String   @map("project_id")
  orgId            String   @map("org_id")
  title            String
  content          String
  source           String   @default("upload") // upload, onboarding, learned
  category         String   @default("standard") // standard, pattern, business, integration
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  project          Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  org              Org      @relation(fields: [orgId], references: [orgId])

  @@index([projectId])
  @@index([orgId])
  @@map("knowledge_entries")
}
