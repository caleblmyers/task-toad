{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:generate": "prisma generate --schema=prisma/schema"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.8.0",
    "graphql-yoga": "^5.0.0",
    "helmet": "^8.1.0",
    "jose": "^5.2.0",
    "nodemailer": "^8.0.2",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^5.14.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3"
  }
}
