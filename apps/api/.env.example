# Production: PORT is auto-set by Railway
PORT=3001
# Production: Set NODE_ENV=production
NODE_ENV=development
# Production: DATABASE_URL is provided by Railway Postgres addon
# Connection pooling: append ?connection_limit=20&pool_timeout=10 to DATABASE_URL for production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasktoad
JWT_SECRET=change-me-to-a-random-secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=change-me-to-a-64-char-hex-string
# Comma-separated allowed origins for CORS (defaults to http://localhost:5173)
# Production: CORS_ORIGINS should be your frontend domain
CORS_ORIGINS=http://localhost:5173

# Email (if not set, links are logged to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tasktoad.app
APP_URL=http://localhost:5173

# GitHub App integration
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# S3-compatible object storage (optional — falls back to local disk if not set)
# Works with AWS S3, Cloudflare R2, MinIO, etc.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Presigned URL expiry in seconds (default: 900 = 15 minutes)
ATTACHMENT_URL_EXPIRY_SECONDS=900

# Stripe billing integration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Sentry error tracking (optional — errors only logged to pino without this)
SENTRY_DSN=
