# Production: VITE_API_URL should point to your API service URL (e.g. https://api.tasktoad.dev)
VITE_API_URL=/api
# GitHub App URL slug (from github.com/apps/<slug>)
VITE_GITHUB_APP_SLUG=
# Sentry DSN for frontend error tracking (optional, only used in production)
VITE_SENTRY_DSN=
# Stripe price IDs for Pro plan checkout
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
